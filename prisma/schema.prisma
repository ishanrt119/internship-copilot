datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // Platform specific fields
  resumeUrl        String?
  skills           Json?
  experience       String?
  preferredRoles   Json?
  location         String?
  remotePreferred  Boolean   @default(false)
  isOnboarded      Boolean   @default(false)

  accounts      Account[]
  sessions      Session[]
  matches       JobMatch[]
  outreaches    Outreach[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Job {
  id              String   @id @default(cuid())
  title           String
  company         String
  location        String?
  applyUrl        String
  description     String
  requiredSkills  Json?
  source          String   // e.g., 'Internshala', 'Indeed'
  isRemote        Boolean  @default(false)
  companyEmail    String?
  companyFounders Json?
  companyAbout    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  matches         JobMatch[]
}

model JobMatch {
  id              String   @id @default(cuid())
  userId          String
  jobId           String
  matchScore      Int      // 0-100
  classification  String   // 'Best Fit', 'Good Fit', 'Stretch'
  explanation     String
  missingSkills   Json?
  status          String   @default("NEW") // 'NEW', 'APPLIED', 'OUTREACH_QUEUED', 'EMAILED'
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  outreach        Outreach? 

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, jobId])
}

model Outreach {
  id          String   @id @default(cuid())
  jobMatchId  String   @unique
  userId      String
  
  initialSent    Boolean  @default(false)
  followUpSent   Boolean  @default(false)
  status         String   @default("PENDING") // 'PENDING', 'SENT', 'DELIVERED', 'OPENED', 'REPLIED'
  nextSendDate   DateTime?

  jobMatch    JobMatch @relation(fields: [jobMatchId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
